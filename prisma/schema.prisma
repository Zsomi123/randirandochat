generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- NEXTAUTH KÖTELEZŐ TÁBLÁK ---

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- A TE FELHASZNÁLÓI TÁBLÁD FELFEJLESZTVE ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // Randirandochat egyedi adatok (opcionálisak, mert bejelentkezés után tölti ki őket)
  becenev       String?
  kor           Int?
  nem           String?
  keresettNem   String?
  megyek        String[]
  hobbik        String[]

  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model NapiLimit {
  azonosito String @id // Ide mentjük be az IP címet (pl. "ip_123.45.67.89") vagy az e-mailt
  hasznalt  Int    @default(0)
  datum     String // Mai dátum (pl. "2026-07-22"), így éjfélkor magától "nullázódik"
}